{
  "name": "share-python",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A browser-based, static Python runner for freeCodeCamp.",
  "scripts": {
    "build:examples": "node scripts/build-examples.mjs",
    "sync:runtimes": "node scripts/sync-runtimes.mjs",
    "dev": "npm run build:examples && npm run sync:runtimes && vite",
    "build": "npm run build:examples && npm run sync:runtimes && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "npm run build:examples && vitest run",
    "test:e2e": "npm run build && playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "@micropython/micropython-webassembly-pyscript": "^1.28.0-preview-233",
    "lz-string": "^1.5.0",
    "pyodide": "^0.29.3"
  }
}
