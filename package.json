{
  "name": "share-python",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A browser-based, static Python runner for freeCodeCamp.",
  "scripts": {
    "build:examples": "node scripts/build-examples.mjs",
    "dev": "npm run build:examples && vite",
    "build": "npm run build:examples && vite build",
    "preview": "vite preview",
    "test": "npm run test:run",
    "test:run": "npm run build:examples && node --test tests/unit/*.test.js"
  },
  "devDependencies": {
    "vite": "^8.0.3"
  }
}
